FASTLANE_APPLE_ID=
FASTLANE_ITC_TEAM_ID=
FASTLANE_TEAM_ID=

APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=

# Alternative to APP_STORE_CONNECT_API_KEY_PATH
APP_STORE_CONNECT_API_KEY_CONTENT=

# Set to 1 if APP_STORE_CONNECT_API_KEY_CONTENT is base64-encoded
APP_STORE_CONNECT_API_KEY_IS_BASE64=0

APP_STORE_COPYRIGHT=2026 Nicolas Toporcov
APP_STORE_SUPPORT_URL=https://github.com/ntoporcov/openclient/issues
APP_STORE_MARKETING_URL=https://open-client.com/
APP_STORE_PRIVACY_URL=https://open-client.com/privacy/

# Set to 1 when you want to upload metadata without screenshots.
FASTLANE_SKIP_SCREENSHOTS=1
