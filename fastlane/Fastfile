require "fileutils"
require "shellwords"

default_platform(:ios)

platform :ios do
  repo_root = File.expand_path("..", __dir__)

  def xcodegen_generate_command(repo_root)
    local_override = File.join(repo_root, "project.local.yml")
    include_local = File.exist?(local_override) ? "INCLUDE_PROJECT_LOCAL_YAML=1 " : ""
    "cd #{repo_root.shellescape} && #{include_local}/Users/mininic/.local/bin/xcodegen generate"
  end

  def screenshot_devices
    [
      "iPhone 11 Pro Max",
      "iPad Pro 13-inch (M5)"
    ]
  end

  def normalize_ipad_landscape_screenshots(screenshot_output, device)
    return unless device.downcase.include?("ipad")

    identifier = device.tr(" ", "-")
    pattern = File.join(screenshot_output, "en_US", "#{identifier}-*.png")
    screenshots = Dir.glob(pattern)
    return if screenshots.empty?

    sh("sips -r 270 #{screenshots.map(&:shellescape).join(" ")}")
  end

  def ensure_screenshot_simulator(device)
    devices = `xcrun simctl list devices available`
    return if devices.include?("#{device} (")

    device_types = {
      "iPhone 11 Pro Max" => "com.apple.CoreSimulator.SimDeviceType.iPhone-11-Pro-Max",
      "iPad Pro 13-inch (M5)" => "com.apple.CoreSimulator.SimDeviceType.iPad-Pro-13-inch-M5-12GB"
    }
    device_type = device_types[device]
    UI.user_error!("No simulator device type configured for #{device}") if device_type.nil?

    sh("xcrun simctl create #{device.shellescape} #{device_type.shellescape} com.apple.CoreSimulator.SimRuntime.iOS-26-2")
  end

  def metadata_path_for_upload(repo_root)
    source = File.join(repo_root, "fastlane", "metadata")
    temp = File.join(repo_root, "build", "fastlane", "metadata-upload")
    FileUtils.rm_rf(temp)
    FileUtils.mkdir_p(temp)
    FileUtils.cp_r(Dir.glob(File.join(source, "*")), temp)
    temp
  end

  def asc_api_key
    key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    key_content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]&.strip
    key_filepath = ENV["APP_STORE_CONNECT_API_KEY_PATH"]&.strip

    key_content = nil if key_content&.empty?
    key_filepath = nil if key_filepath&.empty?

    if key_content && key_filepath
      UI.important("Both APP_STORE_CONNECT_API_KEY_CONTENT and APP_STORE_CONNECT_API_KEY_PATH are set. Preferring APP_STORE_CONNECT_API_KEY_CONTENT.")
      key_filepath = nil
    end

    ENV["APP_STORE_CONNECT_API_KEY_PATH"] = nil if key_filepath.nil?
    ENV["PRECHECK_API_KEY_PATH"] = nil if key_filepath.nil?
    ENV["DELIVER_API_KEY_PATH"] = nil if key_filepath.nil?
    ENV["PILOT_API_KEY_PATH"] = nil if key_filepath.nil?

    if [key_id, issuer_id].any?(&:nil?) || (key_content.nil? && key_filepath.nil?)
      UI.user_error!("Missing App Store Connect API key env vars. Set APP_STORE_CONNECT_API_KEY_ID, APP_STORE_CONNECT_ISSUER_ID, and either APP_STORE_CONNECT_API_KEY_CONTENT or APP_STORE_CONNECT_API_KEY_PATH.")
    end

    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      key_filepath: key_filepath,
      is_key_content_base64: ENV["APP_STORE_CONNECT_API_KEY_IS_BASE64"] == "1",
      duration: 1200,
      in_house: false
    )
  end

  before_all do
    ENV["LANG"] ||= "en_US.UTF-8"
    ENV["LC_ALL"] ||= "en_US.UTF-8"
  end

  desc "Run a simulator build sanity check"
  lane :build do
    sh(xcodegen_generate_command(repo_root))
    build_app(
      project: File.join(repo_root, "OpenCodeIOSClient.xcodeproj"),
      scheme: "OpenCodeIOSClient",
      configuration: "Debug",
      sdk: "iphonesimulator",
      destination: "generic/platform=iOS Simulator",
      skip_archive: true,
      skip_package_ipa: true,
      clean: true,
      output_directory: "build/fastlane"
    )
  end

  desc "Build a release archive for device distribution"
  lane :archive do
    sh(xcodegen_generate_command(repo_root))
    build_app(
      project: File.join(repo_root, "OpenCodeIOSClient.xcodeproj"),
      scheme: "OpenCodeIOSClient",
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic"
      },
      xcargs: "-allowProvisioningUpdates",
      export_xcargs: "-allowProvisioningUpdates",
      output_directory: "build/fastlane",
      output_name: "OpenClient"
    )
  end

  desc "Upload the current build to TestFlight"
  lane :beta do
    api_key = asc_api_key
    archive
    upload_to_testflight(
      api_key: api_key,
      uses_non_exempt_encryption: false,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Submit the current build to App Store Connect"
  lane :release do
    api_key = asc_api_key
    archive
    upload_to_app_store(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      submission_information: {
        export_compliance_uses_encryption: false
      },
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: true
    )
  end

  desc "Validate App Store metadata configuration"
  lane :metadata_check do
    api_key = asc_api_key
    precheck(api_key: api_key, include_in_app_purchases: false)
  end

  desc "Upload App Store metadata without uploading a binary"
  lane :metadata do
    api_key = asc_api_key
    metadata_path = metadata_path_for_upload(repo_root)
    deliver(
      api_key: api_key,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: ENV["FASTLANE_SKIP_SCREENSHOTS"] == "1",
      precheck_include_in_app_purchases: false,
      metadata_path: metadata_path
    )
  end

  desc "Download current App Store metadata into the repo"
  lane :download_metadata do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      force: true,
      download_metadata: true,
      download_screenshots: false,
      metadata_path: File.join(repo_root, "fastlane", "metadata")
    )
  end

  desc "Capture App Store screenshots with deterministic UI tests"
  lane :screenshots do
    sh(xcodegen_generate_command(repo_root))
    screenshot_output = File.join(repo_root, "fastlane", "screenshots")
    FileUtils.rm_rf(screenshot_output)
    FileUtils.mkdir_p(screenshot_output)

    screenshot_devices.each do |device|
      UI.message("Capturing screenshots on #{device}")
      ensure_screenshot_simulator(device)
      sh("xcrun simctl shutdown #{device.shellescape}; xcrun simctl erase #{device.shellescape}; xcrun simctl boot #{device.shellescape}; xcrun simctl bootstatus #{device.shellescape} -b")
      sh(
        [
          "OPENCLIENT_SCREENSHOT_OUTPUT_DIR=#{screenshot_output.shellescape}",
          "xcodebuild",
          "test",
          "-project", File.join(repo_root, "OpenCodeIOSClient.xcodeproj").shellescape,
          "-scheme", "OpenCodeIOSClientScreenshots",
          "-destination", "platform=iOS Simulator,name=#{device},OS=26.2".shellescape,
          "-only-testing:OpenCodeIOSClientUITests/OpenCodeIOSClientUITests/testAppStoreScreenshots",
          "-parallel-testing-enabled", "NO",
          "-maximum-concurrent-test-simulator-destinations", "1",
          "-derivedDataPath", File.join(repo_root, ".derived-data-screenshots").shellescape,
          "ONLY_ACTIVE_ARCH=YES",
        ].join(" ")
      )
      normalize_ipad_landscape_screenshots(screenshot_output, device)
    end
  end
end
